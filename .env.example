# JARVIS Configuration
# Copy this file to .env and fill in your values

# NVIDIA API (required for LLM)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-8b-instruct
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# OpenCode (optional - for coding tasks)
OPENCODE_MODEL=opencode/big-pickle
OPENCODE_BINARY=/Users/brianyang/.opencode/bin/opencode

# Workspace
WORKSPACE_PATH=/Users/brianyang

# Web Server
HOST=127.0.0.1
PORT=8000

# Voice
WHISPER_MODEL=base
TTS_ENABLED=true
TTS_PROVIDER=macos
TTS_VOICE=
TTS_MODEL=tts-1
STT_ENABLED=true
WAKE_WORD_ENABLED=false

# OpenAI (for TTS)
OPENAI_API_KEY=

# Memory
DB_PATH=jarvis.db

# Safety
REQUIRE_CONFIRMATION=true
DANGEROUS_COMMANDS=["rm -rf","sudo","chmod 777","curl | sh","wget | sh","format","mkfs","dd"]

# Agent Configuration
LLM_TEMPERATURE=0.7
MAX_TOKENS=4096
CONFIDENCE_THRESHOLD=0.9

# UI
VIEW_MODE=graph
CHAT_MODE=popup
